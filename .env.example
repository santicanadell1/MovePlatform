# ─── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_USER=move
POSTGRES_PASSWORD=move_secret
POSTGRES_DB=move_db
DATABASE_URL=postgresql://move:move_secret@postgres:5432/move_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=move
RABBITMQ_PASSWORD=move_secret
RABBITMQ_URL=amqp://move:move_secret@rabbitmq:5672

# ─── Firebase Auth ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=move-demo-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@move-demo.iam.gserviceaccount.com

# ─── MercadoPago (sandbox) ────────────────────────────────────────────────────
MP_ACCESS_TOKEN=TEST-xxxx-xxxx-xxxx-xxxx

# ─── OpenRouteService ────────────────────────────────────────────────────────
# Docker local (sin key):  ORS_BASE_URL=http://ors:8080/ors  ORS_API_KEY=
# Cloud openrouteservice.org (con key): ORS_BASE_URL=https://api.openrouteservice.org  ORS_API_KEY=<key>
ORS_BASE_URL=http://ors:8080/ors
ORS_API_KEY=

# ─── Ollama (local Docker) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# ─── Email (Nodemailer + Gmail SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=move.platform.demo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="MOVE Platform <move.platform.demo@gmail.com>"

# ─── Observabilidad ───────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── Puertos de servicios ─────────────────────────────────────────────────────
BOOKING_PORT=3001
OPERATIONS_PORT=3002
TRACKING_PORT=3003

# ─── Pricing defaults (fallback cuando no hay regla en DB para la categoría) ──
PRICING_DEFAULT_BASE_RATE=100
PRICING_DEFAULT_RATE_PER_KM=50
PRICING_DEFAULT_SURCHARGE_PERCENT=0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Mocks (toggle para tests locales) ───────────────────────────────────────
# USE_MOCKS=true   # descomenta para usar MockAuthService, MockPaymentGateway, etc.
