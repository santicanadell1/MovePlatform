{
  "name": "@move/booking-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "test": "jest --runInBand --passWithNoTests",
    "test:coverage": "jest --runInBand --coverage --passWithNoTests",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@move/shared": "workspace:*",
    "express": "^5.0.1",
    "inversify": "^6.0.2",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.23.8",
    "winston": "^3.14.2",
    "prom-client": "^15.1.3",
    "opossum": "^8.1.4",
    "firebase-admin": "^12.4.0",
    "mercadopago": "^2.0.12",
    "nodemailer": "^6.9.14",
    "amqplib": "^0.10.4",
    "bull": "^4.16.3",
    "ioredis": "^5.4.1",
    "@prisma/client": "^5.19.1",
    "prisma": "^5.19.1",
    "pg": "^8.13.0",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.16.5",
    "@types/opossum": "^8.1.7",
    "@types/amqplib": "^0.10.5",
    "@types/bull": "^4.10.0",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "@types/pg": "^8.11.0",
    "@types/jest": "^29.5.13",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
