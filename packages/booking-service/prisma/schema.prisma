generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums (alineados con @move/shared/enums.ts)
// ---------------------------------------------------------------------------

enum UserRole {
  CLIENT_PARTICULAR
  CLIENT_EMPRESA
  OPERATOR
  ADMIN
  CONDUCTOR
}

enum ClientType {
  PARTICULAR
  EMPRESA
}

enum ReservationStatus {
  PENDING_CLASSIFICATION
  PENDING_QUOTE
  QUOTED
  PENDING_PAYMENT
  CONFIRMED
  REJECTED
  ACCEPTED
  ASSIGNED
  CANCELLED
  COMPLETED
}

enum GoodSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id          String     @id @default(cuid())
  firebaseUid String     @unique @map("firebase_uid")
  role        UserRole   @default(CLIENT_PARTICULAR)
  type        ClientType @default(PARTICULAR)
  name        String
  email       String     @unique
  companyName String?    @map("company_name")
  phone       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  reservations     Reservation[]
  companyProducts  CompanyProduct[]
  companyLocations CompanyLocation[]

  @@index([role])
  @@index([type])
  @@map("users")
}

model Reservation {
  id             String            @id @default(cuid())
  clientId       String            @map("client_id")
  client         User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  origin         String
  destination    String
  originLat      Float?            @map("origin_lat")
  originLng      Float?            @map("origin_lng")
  destinationLat Float?            @map("destination_lat")
  destinationLng Float?            @map("destination_lng")
  scheduledDate  DateTime          @map("scheduled_date")
  status         ReservationStatus @default(PENDING_QUOTE)
  totalCost      Decimal?          @map("total_cost") @db.Decimal(12, 2)
  costBreakdown  Json?             @map("cost_breakdown")
  vehicleId      String?           @map("vehicle_id")
  conductorId    String?           @map("conductor_id")
  assignedAt     DateTime?         @map("assigned_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  goods   Good[]
  payment Payment?

  @@index([clientId, status, scheduledDate], map: "idx_reservations_client_status_date")
  @@index([status])
  @@index([createdAt])
  @@map("reservations")
}

model Good {
  id            String   @id @default(cuid())
  reservationId String   @map("reservation_id")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  description   String
  value         Decimal? @db.Decimal(12, 2)
  size          GoodSize?
  quantity      Int      @default(1)
  categoryId    String?  @map("category_id")
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productId     String?  @map("product_id")
  product       CompanyProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  classificationStrategy String? @map("classification_strategy")
  classificationConfidence Float? @map("classification_confidence")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([reservationId])
  @@index([categoryId])
  @@map("goods")
}

model Payment {
  id                    String        @id @default(cuid())
  reservationId         String        @unique @map("reservation_id")
  reservation           Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("UYU")
  status                PaymentStatus @default(PENDING)
  provider              String
  providerTransactionId String?       @map("provider_transaction_id")
  attemptedAt           DateTime      @default(now()) @map("attempted_at")
  completedAt           DateTime?     @map("completed_at")
  errorMessage          String?       @map("error_message")
  createdAt             DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@map("payments")
}

model Category {
  id                 String  @id @default(cuid())
  nameEs             String  @unique @map("name_es")
  nameEn             String  @unique @map("name_en")
  description        String?
  examples           Json?
  requiresMonitoring Boolean @default(false) @map("requires_monitoring")
  generatesAlerts    Boolean @default(false) @map("generates_alerts")
  surchargePercent   Float   @default(0) @map("surcharge_percent")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  goods           Good[]
  pricingRules    PricingRule[]
  companyProducts CompanyProduct[]

  @@map("categories")
}

model PricingRule {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  rules      Json     @default("{}")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([active])
  @@map("pricing_rules")
}

model CompanyProduct {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  client     User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  goods         Good[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([categoryId])
  @@map("company_products")
}

model CompanyLocation {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  address   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, name])
  @@index([clientId])
  @@map("company_locations")
}
