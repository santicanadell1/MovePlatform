{
  "name": "@move/ai-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --runInBand --passWithNoTests"
  },
  "dependencies": {
    "@move/shared": "workspace:*",
    "amqplib": "^0.10.4",
    "bull": "^4.16.3",
    "ioredis": "^5.4.1",
    "winston": "^3.14.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bull": "^4.10.0",
    "@types/node": "^20.16.5",
    "@types/jest": "^29.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
