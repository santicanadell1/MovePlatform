{
  "name": "@move/operations-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "test": "jest --runInBand --passWithNoTests",
    "test:coverage": "jest --runInBand --coverage --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "seed": "ts-node --project tsconfig.scripts.json --transpile-only scripts/seed-categories.ts",
    "seed:demo": "ts-node --project tsconfig.scripts.json --transpile-only scripts/seed-demo.ts"
  },
  "dependencies": {
    "@move/shared": "workspace:*",
    "@prisma/client": "^5.19.1",
    "amqplib": "^0.10.4",
    "csv-parse": "^6.2.1",
    "cuid": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "firebase-admin": "^12.4.0",
    "helmet": "^7.1.0",
    "inversify": "^6.0.2",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "prisma": "^5.19.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/cuid": "^2.0.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
