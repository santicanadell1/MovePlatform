{
  "id": null,
  "uid": "move-overview",
  "title": "MOVE Platform Overview",
  "tags": ["move"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total[5m]) * 60)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tasa de errores 5xx",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Latencia",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latencia p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Negocio",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Reservas creadas / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "sum by (client_type) (rate(reservations_created_total[5m]) * 60)",
          "legendFormat": "{{client_type}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Puntos GPS procesados / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        {
          "expr": "sum by (result) (rate(gps_points_processed_total[5m]) * 60)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Alertas generadas / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "expr": "sum by (alert_type) (rate(alerts_generated_total[5m]) * 60)",
          "legendFormat": "{{alert_type}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Node.js Process",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Heap used (MB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "MB" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Active handles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    }
  ]
}
